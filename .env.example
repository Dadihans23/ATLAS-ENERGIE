# ─────────────────────────────────────────────
#  .env.example – Copier en .env et adapter
#  NE JAMAIS committer le .env réel
# ─────────────────────────────────────────────

# Sécurité
SECRET_KEY=changez-cette-cle-secrete-tres-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (SQLite par défaut)
DATABASE_URL=sqlite:///db.sqlite3

# Fichiers médias
MEDIA_ROOT=media
MEDIA_URL=/media/

# Fichiers statiques
STATIC_ROOT=staticfiles
STATIC_URL=/static/

# Site ID (django.contrib.sites)
SITE_ID=1

# Email (dev → console, prod → SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@atlas-energies.ci

# Taux de change (XOF – mis à jour manuellement)
TAUX_EUR_XOF=655.957
TAUX_USD_XOF=605.00

# Taille max upload (en Mo)
MAX_UPLOAD_SIZE_MB=10
